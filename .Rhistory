library(scales)
knitr::opts_chunk$set(
echo = FALSE, warning = FALSE, message = FALSE
)
library(tidyverse)
library(knitr)
library(readr)
library(janitor)
library(gtsummary)
library(scales)
# Read & open dataset
prem_20 <- read_csv("Prem_2020.csv")
head(prem_20)
summary(prem_20)
# Clean all variable names
prem_clean <- prem_2020 %>%
janitor::clean_names()
# Clean all variable names
prem_clean <- prem_20 %>%
janitor::clean_names()
# Check total missing values in dataset
total_missing <- sum(is.na(prem_clean))
total_missing
# Missing values by column
missing_by_column <- colSums(is.na(prem_clean))
missing_by_column
head(prem_clean)
# Count and show all distinct positions
n_distinct(prem_clean$position)
unique(prem_clean$position)
# Create performance summary by position
table_pos <- prem_clean %>%
mutate(
goal_contribution = goals + assists
) %>%
group_by(position) %>%
summarise(
n_players = n(),
mean_appearances = mean(appearances, na.rm = TRUE),
median_appearances = median(appearances, na.rm = TRUE),
mean_goals = mean(goals, na.rm = TRUE),
median_goals = median(goals, na.rm = TRUE),
mean_assists = mean(assists, na.rm = TRUE),
median_assists = median(assists, na.rm = TRUE),
mean_goal_contribution = mean(goal_contribution, na.rm = TRUE),
median_goal_contribution = median(goal_contribution, na.rm = TRUE),
.groups = "drop"
) %>%
arrange(desc(mean_goal_contribution))
# Formatted table by position
table_pos %>%
mutate(
mean_appearances = round(mean_appearances, 1),
median_appearances = round(median_appearances, 1),
mean_goals = round(mean_goals, 2),
median_goals = round(median_goals, 2),
mean_assists = round(mean_assists, 2),
median_assists = round(median_assists, 2),
mean_goal_contribution = round(mean_goal_contribution, 2),
median_goal_contribution = round(median_goal_contribution, 2)
) %>%
knitr::kable(
caption = "Performance summary by position (Premier League 2020)",
col.names = c(
"Position", "N",
"Mean apps", "Median apps",
"Mean goals", "Median goals",
"Mean assists", "Median assists",
"Mean (G+A)", "Median (G+A)"
)
)
## Table
table_pos <- prem_clean %>%
mutate(goal_contribution = goals + assists) %>%
group_by(position) %>%
summarise(
n_players = n(),
mean_apps = mean(appearances, na.rm = TRUE),
mean_goals = mean(goals, na.rm = TRUE),
mean_assists = mean(assists, na.rm = TRUE),
mean_g_a = mean(goal_contribution, na.rm = TRUE),
.groups = "drop"
) %>%
arrange(desc(mean_g_a))
knitr::kable(
table_pos,
caption = "Premier League 2020: average performance by position",
digits = 2,
col.names = c("Position", "N", "Mean apps", "Mean goals", "Mean assists", "Mean (G+A)")
)
