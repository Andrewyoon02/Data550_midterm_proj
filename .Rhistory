) %>%
arrange(desc(mean_value_eur))
# Formatted table (top 12 positions by mean value)
table_pos %>%
mutate(
mean_value_eur = scales::dollar(mean_value_eur, accuracy = 1),
median_value_eur = scales::dollar(median_value_eur, accuracy = 1),
mean_overall = round(mean_overall, 1)
) %>%
slice_head(n = 12) %>%
knitr::kable(
caption = "Market value summary by position (top 12 by mean market value)",
col.names = c("Position", "N", "Mean market value (EUR)", "Median market value (EUR)", "Mean overall rating"),
align = "lrrrrr"
)
# Count and show all distinct positions
n_distinct(fifa_clean$position)
unique(fifa_clean$position)
# Create market value in euros (change from "in millions")
table_pos <- fifa_clean %>%
mutate(market_value_eur = market_value_million_eur * 1e6) %>%
group_by(position) %>%
summarise(
n_players = n(),
mean_value_eur = mean(market_value_eur),
median_value_eur = median(market_value_eur),
mean_overall = mean(overall_rating),
.groups = "drop") %>%
arrange(desc(mean_value_eur))
# Formatted table by position in dollars
table_pos %>%
mutate(
mean_value_eur = scales::dollar(mean_value_eur, accuracy = 1),
median_value_eur = scales::dollar(median_value_eur, accuracy = 1),
mean_overall = round(mean_overall, 1)
) %>%
knitr::kable(
caption = "Market value summary by position (mean market value)",
col.names = c("Position", "N", "Mean market value (USD)", "Median market value (USD)", "Mean overall rating")
)
ggplot(fifa2, aes(x = overall_num, y = market_value_num)) +
geom_point(alpha = 0.35, size = 1.8) +
scale_y_log10(labels = dollar_format()) +
labs(
title = "Market value vs overall rating",
x = "Overall rating",
y = "Market value (log scale)"
) +
theme_minimal(base_size = 12)
