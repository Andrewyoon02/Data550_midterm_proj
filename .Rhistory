```{r, heatmap-overall-marketvalue}
# EUR -> USD exchange rate
eur_to_usd <- 1.10
# Prepare data
heatmap_data <- fifa_clean %>%
mutate(
market_value_eur = market_value_million_eur * 1e6,
market_value_usd = market_value_eur * eur_to_usd
)
# Check min and max market values (USD)
min_value <- min(heatmap_data$market_value_usd, na.rm = TRUE)
max_value <- max(heatmap_data$market_value_usd, na.rm = TRUE)
min_value
max_value
# Create breaks dynamically (6 groups between min and max)
value_breaks <- seq(min_value, max_value, length.out = 7)
# Build heatmap dataset
heatmap_data <- heatmap_data %>%
mutate(
overall_group = cut(
overall_rating,
breaks = seq(60, 100, by = 10),
include.lowest = TRUE,
right = FALSE,
labels = c("60–69", "70–79", "80–89", "90–99")
),
value_group = cut(
market_value_usd,
breaks = value_breaks,
include.lowest = TRUE
)
) %>%
filter(!is.na(overall_group), !is.na(value_group))
# Count players in each bin
heatmap_counts <- heatmap_data %>%
count(overall_group, value_group)
# Heatmap
ggplot(heatmap_counts, aes(x = overall_group, y = value_group, fill = n)) +
geom_tile(color = "white") +
scale_fill_viridis_c(option = "C", name = "Number of players") +
labs(
title = "Heatmap of overall rating vs market value (USD)",
x = "Overall rating category",
y = "Market value category (USD)"
) +
theme_minimal(base_size = 12)
plot_data <- fifa_clean %>%
mutate(
goal_contribution = goals + assists,
rating_group = cut(
overall_rating,
breaks = c(60, 70, 80, 90, 95),
right = FALSE,
include.lowest = TRUE,
labels = c("60–69", "70–79", "80–89", "90–94")
)
) %>%
filter(
!is.na(matches_played),
!is.na(goal_contribution),
!is.na(rating_group)
)
ggplot(plot_data, aes(x = matches_played, y = goal_contribution, color = rating_group)) +
geom_point(alpha = 0.6, size = 2) +
labs(
title = "Games played vs goal contributions",
x = "Games played",
y = "Goal contributions (goals + assists)",
color = "Overall rating"
) +
theme_minimal(base_size = 12)
plot_data <- fifa_clean %>%
mutate(
goal_contribution = goals + assists,
# Create rating categories
rating_group = cut(
overall_rating,
breaks = c(60, 70, 80, 90, 95),
right = FALSE,
include.lowest = TRUE,
labels = c("60–69", "70–79", "80–89", "90–94")
),
# Collapse detailed positions into broader groups
position_group = case_when(
position %in% c("ST","LW","RW") ~ "Forward",
position %in% c("CM","CDM") ~ "Midfielder",
position %in% c("CB","LB","RB") ~ "Defender",
position %in% c("GK") ~ "Goalkeeper",
TRUE ~ "Other"
)
) %>%
filter(
!is.na(matches_played),
!is.na(goal_contribution),
!is.na(rating_group),
!is.na(position_group)
)
ggplot(plot_data, aes(x = matches_played, y = goal_contribution, color = position_group)) +
geom_point(alpha = 0.6, size = 2) +
labs(
title = "Games played vs goal contributions by rating category and position group",
x = "Games played",
y = "Goal contributions (goals + assists)",
color = "Position group"
) +
facet_wrap(~ rating_group, ncol = 2) +
theme_minimal(base_size = 12)
